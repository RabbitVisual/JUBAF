        <testsuite name="Modules">
            <directory>Modules/*/tests/Feature</directory>
            <directory>Modules/*/tests/Unit</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing" force="true"/>
