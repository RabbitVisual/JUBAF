SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:8000,::1
SANCTUM_TOKEN_PREFIX=

MODULE_VENDOR=vertex-solutions
MODULE_AUTHOR_NAME="Vertex Solutions LTDA"
MODULE_AUTHOR_EMAIL=dev@vertexsolutions.com.br

VITE_APP_NAME="${APP_NAME}"

# Módulos JUBAF — Notificações (e-mail, Evolution API), Financeiro (quotas), Igrejas (alertas)
# Também editável em Admin → Configurações → «Notificações e módulos» (sincroniza com o .env).

NOTIFICACOES_EMAIL_ENABLED=false
NOTIFICACOES_POLLING_INTERVAL=30000
NOTIFICACOES_BROADCASTING_ENABLED=true
NOTIFICACOES_WHATSAPP_BASE_URL=
NOTIFICACOES_WHATSAPP_TOKEN=

EVOLUTION_API_URL=
